<?xml version="1.0" encoding="utf-8"?>
<!--
    item_transaccion.xml
    Tarjeta individual de una transacción.
    Muestra: servicio asociado, rol del usuario (comprador/vendedor),
    estado, horas, y botones de acción según el contexto.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:contentPadding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Rol del usuario en esta transacción -->
        <TextView
            android:id="@+id/tvRol"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="COMPRADOR" />

        <!-- Estado de la transacción -->
        <TextView
            android:id="@+id/tvEstadoTransaccion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="PENDIENTE" />

        <!-- ID del servicio / título -->
        <TextView
            android:id="@+id/tvTituloTransaccion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tvRol"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Clases de inglés" />

        <!-- Horas de la transacción -->
        <TextView
            android:id="@+id/tvHorasTransaccion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvTituloTransaccion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="1.5 h" />

        <!-- Fecha -->
        <TextView
            android:id="@+id/tvFechaTransaccion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="11sp"
            app:layout_constraintTop_toBottomOf="@id/tvHorasTransaccion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="19/03/2026 17:30" />

        <!-- Contenedor de botones de acción -->
        <LinearLayout
            android:id="@+id/llBotones"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvFechaTransaccion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Botón positivo (Aceptar / Completar) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPositivo"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="Aceptar"
                tools:visibility="visible" />

            <!-- Botón negativo (Cancelar / Rechazar) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNegativo"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="Cancelar"
                tools:visibility="visible" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>