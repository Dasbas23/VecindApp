<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_escaparate.xml
    Layout principal del escaparate de servicios.
    Contiene un RecyclerView que muestra las tarjetas de servicios activos.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.escaparate.EscaparateFragment">

    <!-- Título de la pantalla -->
    <TextView
        android:id="@+id/tvTituloEscaparate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/titulo_escaparate"
        android:textSize="22sp"
        android:textStyle="bold"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Lista de servicios -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEscaparate"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloEscaparate"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_servicio" />

    <!-- Mensaje cuando no hay servicios -->
    <TextView
        android:id="@+id/tvVacio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/escaparate_vacio"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rvEscaparate"
        app:layout_constraintBottom_toBottomOf="@id/rvEscaparate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>