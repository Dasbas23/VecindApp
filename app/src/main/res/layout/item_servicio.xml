<?xml version="1.0" encoding="utf-8"?>
<!--
    item_servicio.xml
    Tarjeta individual de un servicio en el escaparate.
    Muestra: pictograma ARASAAC, título, categoría y coste en horas.
-->
<com.google.android.material.card.MaterialCardView
    android:background="#FF0000"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:contentPadding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Pictograma ARASAAC del servicio -->
        <ImageView
            android:id="@+id/ivPictograma"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="@string/desc_pictograma"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@tools:sample/avatars" />

        <!-- Título del servicio -->
        <TextView
            android:id="@+id/tvTituloServicio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="@id/ivPictograma"
            app:layout_constraintStart_toEndOf="@id/ivPictograma"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Paseo de mascotas" />

        <!-- Categoría del servicio -->
        <TextView
            android:id="@+id/tvCategoriaServicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/tvTituloServicio"
            app:layout_constraintStart_toEndOf="@id/ivPictograma"
            tools:text="COMPANIA" />

        <!-- Coste en horas -->
        <TextView
            android:id="@+id/tvCosteServicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tvCategoriaServicio"
            app:layout_constraintStart_toEndOf="@id/ivPictograma"
            tools:text="1.5 h" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>